# Frontend URL
NEXT_PUBLIC_URL=http://localhost:3000

# Database (For client-side Prisma schema verification/generation)
DATABASE_URL="postgresql://username:password@hostname:5432/database"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Botpress Configuration
NEXT_PUBLIC_BOTPRESS_BOT_ID=your_botpress_bot_id
NEXT_PUBLIC_BOTPRESS_INJECT_URL="https://cdn.botpress.cloud/webchat/v3.6/inject.js"
NEXT_PUBLIC_BOTPRESS_CONFIG_URL="your_botpress_config_url"
