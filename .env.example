# --- App ---
NEXT_PUBLIC_URL=http://localhost:3000

# --- Supabase (browser sign-in) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Database (Prisma CLI / build only) ---
DATABASE_URL=postgresql://username:password@hostname:5432/database

# --- Botpress chat widget ---
NEXT_PUBLIC_BOTPRESS_INJECT_URL=https://cdn.botpress.cloud/webchat/v3.6/inject.js
NEXT_PUBLIC_BOTPRESS_CONFIG_URL=your_botpress_config_url
