# Frontend Portal URL (used for CORS and redirect URLs)
NEXT_PUBLIC_URL=http://localhost:3000

# Backend Server Configuration
PORT=5000

# Supabase Configuration
DATABASE_URL="postgresql://username:password@hostname:5432/database"
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email Configuration (SMTP)
SENDER_EMAIL=noreply@example.com
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USER="smtp_username"
SMTP_PASS="smtp_password"

# Session & JWT Secrets
SESSION_SECRET=super_secret_key_change_me_in_production

# Salesforce OAuth Encryption Key (32-character hex key)
SALESFORCE_ENCRYPTION_KEY=change_me_to_a_32_char_hex_key_00

# AI Services
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6

#Google Meet Auth
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/sales/scheduling/google/callback

# Inbound Webhook shared-secret token (Brevo email webhooks + Twilio fallback auth)
INBOUND_WEBHOOK_SECRET=change_me_long_random_string

# Twilio SMS infrastructure config.
TWILIO_VALIDATE_SIGNATURE=0

COMPLAINT_RATE_THRESHOLD=0.001
COMPLAINT_RATE_WINDOW_HOURS=24
COMPLAINT_RATE_MIN_VOLUME=100
COMPLIANCE_ALERT_EMAIL=

# Inngest Cloud Configuration (Production)
INNGEST_DEV=0
INNGEST_EVENT_KEY=your_inngest_production_event_key
INNGEST_SIGNING_KEY=your_inngest_production_signing_key

# ─── Sales Knowledge Base (RAG) — SW-KB ───────────────────────────────────────
# Embeddings: OpenAI text-embedding-3-small (1536 dims).
OPENAI_API_KEY=
# Pinecone vector DB. Create a serverless index with dimension=1536, metric=cosine,
# and put its name in PINECONE_INDEX.
PINECONE_API_KEY=
PINECONE_INDEX=ailumen-sales-kb
