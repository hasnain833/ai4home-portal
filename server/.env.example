# Frontend Portal URL (used for CORS and redirect URLs)
NEXT_PUBLIC_URL=http://localhost:3000

# Backend Server Configuration
PORT=5000

# Database Connection (Prisma)
DATABASE_URL="postgresql://username:password@hostname:5432/database"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email Configuration (SMTP)
SENDER_EMAIL=noreply@example.com
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USER="smtp_username"
SMTP_PASS="smtp_password"

# Session & JWT Secrets
SESSION_SECRET=super_secret_key_change_me_in_production

# Salesforce OAuth Encryption Key (32-character hex key)
SALESFORCE_ENCRYPTION_KEY=change_me_to_a_32_char_hex_key_00

# AI Services
GEMINI_API_KEY=your_gemini_api_key

# Appointment Scheduling Agent (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key
# Optional model override for the booking agent (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Calendar / Meet integration (OAuth 2.0)
# Redirect URI must EXACTLY match one registered in the Google Cloud console and point
# at the backend callback, e.g. https://your-app.com/api/sales/scheduling/google/callback
# For local dev: http://localhost:3000/api/sales/scheduling/google/callback
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/sales/scheduling/google/callback

TWILIO_AUTH_TOKEN=your_twilio_auth_token
INBOUND_WEBHOOK_SECRET=change_me_long_random_string
WEBHOOK_BASE_URL=

COMPLAINT_RATE_THRESHOLD=0.001
COMPLAINT_RATE_WINDOW_HOURS=24
COMPLAINT_RATE_MIN_VOLUME=100
COMPLIANCE_ALERT_EMAIL=

# Inngest Cloud Configuration (Production)
INNGEST_DEV=0
INNGEST_EVENT_KEY=your_inngest_production_event_key
INNGEST_SIGNING_KEY=your_inngest_production_signing_key
