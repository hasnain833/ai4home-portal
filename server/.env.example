# --- App ---
NEXT_PUBLIC_URL=http://localhost:3000
PORT=5000
NODE_ENV=development

# --- Database ---
DATABASE_URL=postgresql://username:password@hostname:5432/database

# --- Supabase (auth + file storage) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Secrets & encryption ---
APP_ENCRYPTION_KEY=
# Only while rotating the key; remove afterwards.
APP_ENCRYPTION_KEY_PREVIOUS=
SESSION_SECRET=

# --- Email configuration (SMTP fallback) ---
SENDER_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Twilio configuration (SMS fallback) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_VALIDATE_SIGNATURE=false
TWILIO_WEBHOOK_BASE_URL=
TWILIO_STATUS_CALLBACK_URL=

# --- Webhook secrets ---
INBOUND_WEBHOOK_SECRET=
BOTPRESS_WEBHOOK_SECRET=

# --- AI providers (keys only; models set in code) ---
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
TRANSFORMERS_CACHE=

# --- Virus scanning (optional; pick one) ---
CLAMAV_HOST=
AV_SCAN_URL=
AV_SCAN_API_KEY=
AV_SCAN_REQUIRED=false

# --- Google Calendar (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- Background jobs (Inngest) ---
INNGEST_DEV=1
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Super admin login ---
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_SESSION_SECRET=

# --- Alert recipient ---
COMPLIANCE_ALERT_EMAIL=

# Legacy alias for APP_ENCRYPTION_KEY. Only needed on older deployments.
SALESFORCE_ENCRYPTION_KEY=
