# Frontend Portal URL (used for CORS and redirect URLs)
NEXT_PUBLIC_URL=http://localhost:3000

# Backend Server Configuration
PORT=5000

# Database Connection (Prisma)
DATABASE_URL="postgresql://username:password@hostname:5432/database"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email Configuration (SMTP)
SENDER_EMAIL=noreply@example.com
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USER="smtp_username"
SMTP_PASS="smtp_password"

# Session & JWT Secrets
SESSION_SECRET=super_secret_key_change_me_in_production

# Salesforce OAuth Encryption Key (32-character hex key)
SALESFORCE_ENCRYPTION_KEY=change_me_to_a_32_char_hex_key_00

# Brevo SMS Services
BREVO_API_KEY=your_brevo_api_key
BREVO_SMS_SENDER=Aiforhomebuilder

# AI Services
GEMINI_API_KEY=your_gemini_api_key
