generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STAFF
  HOMEOWNER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ESCALATED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  name            String?
  avatar          String?   // Personal avatar for staff members
  role            Role      @default(HOMEOWNER)
  companyId       String?
  company         Company?  @relation(fields: [companyId], references: [id])
  properties      Property[]
  tickets         Ticket[]  @relation("HomeownerTickets")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Company {
  id              String               @id @default(cuid())
  name            String
  logo            String?
  email           String?
  phone           String?
  address         String?
  warrantyPolicy  String?              @db.Text
  botColor        String?              @default("#0F3B3D")
  users           User[]
  knowledgeBase   KnowledgeBaseDocument[]
  integrations    Integration[]
  communities     Community[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model Integration {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  platform    String   // "BUILTOPIA", "BUILDERTREND", etc.
  apiKey      String
  secretKey   String?
  environment String   @default("production")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Property {
  id            String    @id @default(cuid())
  address       String
  city          String?
  state         String?
  zipCode       String?
  areaOfHome    String?
  coeDate       DateTime?
  coverageTerm  DateTime?
  homeownerId   String
  homeowner     User      @relation(fields: [homeownerId], references: [id])
  tickets       Ticket[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Ticket {
  id            String         @id @default(cuid())
  issueType     String
  ticketType    String?
  description   String?        @db.Text
  status        TicketStatus   @default(OPEN)
  priority      TicketPriority @default(MEDIUM)
  isEmergency   Boolean        @default(false)
  warrantyYear  Int            @default(1)
  erpSyncStatus String?        @default("PENDING")
  erpReferenceId String?
  draftResponse String?        @db.Text
  chatSummary   String?        @db.Text
  extractedInfo String?        @db.Text
  kbReferences  String?        @db.Text
  homeownerId   String
  homeowner     User           @relation("HomeownerTickets", fields: [homeownerId], references: [id])
  propertyId    String?
  property      Property?      @relation(fields: [propertyId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}


enum DocumentType {
  MANUAL
  VIDEO
  DIY_GUIDE
}

model Community {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  color       String   @default("#0F3B3D")
  documents   KnowledgeBaseDocument[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KnowledgeBaseDocument {
  id            String         @id @default(cuid())
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  communityId   String?
  community     Community?     @relation(fields: [communityId], references: [id], onDelete: SetNull)
  name          String
  size          String
  url           String
  documentType  DocumentType   @default(MANUAL)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}
