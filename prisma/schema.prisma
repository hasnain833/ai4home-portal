generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
  HOMEOWNER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ESCALATED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id                  String             @id @default(cuid())
  email               String             @unique
  password            String
  name                String?
  avatar              String? // Personal avatar for staff members
  role                Role               @default(HOMEOWNER)
  companyId           String?
  company             Company?           @relation(fields: [companyId], references: [id])
  properties          Property[]
  tickets             Ticket[]           @relation("HomeownerTickets")
  knowledgeBaseId     String?
  hasWarrantyAccess   Boolean            @default(true)
  hasSalesAccess      Boolean            @default(false)
  lastActiveWorkspace String?            @default("warranty")
  ownedLeads          Lead[]             @relation("LeadOwner")
  agentAppointments   SalesAppointment[] @relation("AgentAppointments")
  contentCalendars    ContentCalendar[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([companyId])
}

model Company {
  id                      String                  @id @default(cuid())
  name                    String
  logo                    String?
  email                   String?
  phone                   String?
  address                 String?
  warrantyPolicy          String?                 @db.Text
  botColor                String?                 @default("#0F3B3D")
  users                   User[]
  knowledgeBase           KnowledgeBaseDocument[]
  integrations            Integration[]
  communities             Community[]
  leads                   Lead[]
  segments                LeadSegment[]
  salesforceConnection    SalesforceConnection?
  knowledgeBaseId         String?
  defaultLeadOwner        String?
  voiceProfile            String?                 @default("professional")
  salesBrandProfile       Json?
  maxSmsPerHour           Int                     @default(60)
  complianceOptInRequired Boolean                 @default(true)
  smsQuietHoursEnabled    Boolean                 @default(true)
  quietHoursStart         Int                     @default(8)
  quietHoursEnd           Int                     @default(21)
  quietHoursTimezone      String?
  leadStatuses            Json?
  newsSources             Json?
  salesEnabled            Boolean                 @default(false)
  warrantyEnabled         Boolean                 @default(true)
  verificationStatus      String                  @default("PENDING")
  verificationDocUrl      String?
  verificationSubmittedAt DateTime?
  verifiedAt              DateTime?
  automationsKillSwitch   Boolean                 @default(false)
  automationDailyCap      Int                     @default(1000)
  campaignExitConditions  Json?
  campaignVersionPolicy   String                  @default("FINISH_OLD")
  marketingRules          MarketingRule[]
  suppressionList         SuppressionList[]
  campaigns               Campaign[]
  emailTemplates          EmailTemplate[]
  calendarEvents          ContentCalendar[]
  salesKB                 SalesKB[]
  announcements           Announcement[]
  availabilitySetting     AvailabilitySetting?
  calendarConnections     CalendarConnection[]
  scrapedNews             ScrapedNews[]
  blogPosts               BlogPost[]
  csvMappingTemplates     CsvMappingTemplate[]
  tickets                 Ticket[]
  properties              Property[]
  appointmentMode         String                  @default("AI")
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
}

// SW-CSV-002: saved CSV column→field mapping templates, reusable across imports.
model CsvMappingTemplate {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  mapping   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
}

model Integration {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id])
  platform    String
  apiKey      String?
  secretKey   String?
  environment String  @default("production")
  isActive    Boolean @default(true)
  smtpHost    String?
  smtpPort    Int?
  senderEmail String?
  senderName  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Property {
  id           String    @id @default(cuid())
  address      String
  city         String?
  state        String?
  zipCode      String?
  areaOfHome   String?
  coeDate      DateTime?
  coverageTerm DateTime?
  homeownerId  String
  homeowner    User      @relation(fields: [homeownerId], references: [id])
  companyId    String?
  company      Company?  @relation(fields: [companyId], references: [id])
  tickets      Ticket[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([homeownerId])
  @@index([companyId])
}

model Ticket {
  id             String         @id @default(cuid())
  issueType      String
  ticketType     String?
  description    String?        @db.Text
  status         TicketStatus   @default(OPEN)
  priority       TicketPriority @default(MEDIUM)
  isEmergency    Boolean        @default(false)
  warrantyYear   Int            @default(1)
  erpSyncStatus  String?        @default("PENDING")
  erpReferenceId String?
  draftResponse  String?        @db.Text
  chatSummary    String?        @db.Text
  extractedInfo  String?        @db.Text
  kbReferences   String?        @db.Text
  homeownerId    String
  homeowner      User           @relation("HomeownerTickets", fields: [homeownerId], references: [id])
  propertyId     String?
  property       Property?      @relation(fields: [propertyId], references: [id])
  companyId      String?
  company        Company?       @relation(fields: [companyId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([homeownerId])
  @@index([propertyId])
  @@index([companyId, status])
  @@index([status])
}

model Community {
  id        String                  @id @default(cuid())
  companyId String
  company   Company                 @relation(fields: [companyId], references: [id])
  name      String
  color     String                  @default("#0F3B3D")
  documents KnowledgeBaseDocument[]
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@index([companyId])
}

model KnowledgeBaseDocument {
  id          String     @id @default(cuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  communityId String?
  community   Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)
  name        String
  size        String
  url         String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([companyId])
  @@index([communityId])
}

enum LeadSource {
  SALESFORCE
  CSV
  MANUAL
}

model Lead {
  id                      String                   @id @default(cuid())
  companyId               String
  company                 Company                  @relation(fields: [companyId], references: [id])
  source                  LeadSource               @default(MANUAL)
  externalId              String?
  firstName               String
  lastName                String
  email                   String?
  phone                   String?
  street                  String?
  city                    String?
  state                   String?
  zipCode                 String?
  status                  String                   @default("New")
  ownerId                 String?
  owner                   User?                    @relation("LeadOwner", fields: [ownerId], references: [id])
  tags                    String[]                 @default([])
  emailOptIn              Boolean                  @default(false)
  smsOptIn                Boolean                  @default(false)
  consentSource           String?
  consentTimestamp        DateTime?
  customFields            Json?
  archived                Boolean                  @default(false)
  archivedAt              DateTime?
  timeline                LeadTimeline[]
  appointments            SalesAppointment[]
  campaignEnrollments     CampaignEnrollment[]
  schedulingConversations SchedulingConversation[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  @@index([companyId, status])
  @@index([companyId, email])
  @@index([companyId, phone])
  @@index([ownerId])
  @@index([companyId, archived])
}

model LeadTimeline {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        String
  description String   @db.Text
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([leadId, createdAt])
}

model LeadSegment {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  filters   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model SalesAppointment {
  id              String    @id @default(cuid())
  leadId          String
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  title           String
  time            DateTime
  endTime         DateTime?
  durationMinutes Int       @default(30)
  status          String    @default("CONFIRMED")
  locationType    String    @default("VIRTUAL")
  meetingLink     String?
  googleEventId   String?
  notes           String?   @db.Text
  leadTimezone    String?
  bookedVia       String    @default("STAFF")
  rescheduleToken String    @unique @default(cuid())
  cancelToken     String    @unique @default(cuid())
  reminder24Sent  Boolean   @default(false)
  reminder1Sent   Boolean   @default(false)
  agentId         String
  agent           User      @relation("AgentAppointments", fields: [agentId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([agentId, time])
  @@index([leadId])
  @@index([status, time])
}

model SalesforceConnection {
  id              String    @id @default(cuid())
  companyId       String    @unique
  company         Company   @relation(fields: [companyId], references: [id])
  instanceUrl     String
  accessToken     String    @db.Text
  refreshToken    String    @db.Text
  tokenExpiresAt  DateTime
  environment     String    @default("sandbox")
  clientId        String
  clientSecret    String    @db.Text
  syncInterval    Int       @default(15)
  isActive        Boolean   @default(true)
  lastSyncAt      DateTime?
  lastSyncStatus  String?
  lastSyncMessage String?   @db.Text
  writeBackEnabled Boolean  @default(false)
  lastWriteBackAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model SyncLog {
  id          String   @id @default(cuid())
  companyId   String
  direction   String
  action      String
  status      String
  recordCount Int      @default(0)
  errorCount  Int      @default(0)
  message     String?  @db.Text
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([companyId, createdAt])
}

model SalesforceFieldMapping {
  id              String   @id @default(cuid())
  companyId       String
  salesforceField String
  portalField     String
  description     String?
  isActive        Boolean  @default(true)
  isConsentField  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([companyId, salesforceField])
}

model SuppressionList {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  value     String
  reason    String
  createdAt DateTime @default(now())

  @@unique([companyId, value])
}

enum StepType {
  EMAIL
  SMS
  DELAY
}

model Campaign {
  id              String               @id @default(cuid())
  companyId       String
  company         Company              @relation(fields: [companyId], references: [id])
  name            String
  description     String?
  status          String               @default("Draft")
  channel         String               @default("Email & SMS")
  appointmentMode String               @default("INHERIT")
  exitConditions  Json?
  versionPolicy   String               @default("FINISH_OLD")
  steps           CampaignStep[]
  enrollments     CampaignEnrollment[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([companyId, status])
}

model CampaignStep {
  id              String         @id @default(cuid())
  campaignId      String
  campaign        Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type            StepType
  position        Int
  delayValue      Int?
  delayUnit       String?
  sendWindowDays  String?
  sendWindowStart String?
  sendWindowEnd   String?
  subject         String?
  body            String?
  templateId      String?
  template        EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sentCount       Int            @default(0)
  deliveredCount  Int            @default(0)
  openedCount     Int            @default(0)
  clickedCount    Int            @default(0)
  repliedCount    Int            @default(0)
  bouncedCount    Int            @default(0)
  complaintCount  Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([campaignId])
}

model CampaignEnrollment {
  id                  String    @id @default(cuid())
  leadId              String
  lead                Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaignId          String
  campaign            Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  status              String    @default("ACTIVE")
  exitedReason        String?
  currentStepPosition Int       @default(0)
  nextRunAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([leadId, campaignId])
  @@index([status, nextRunAt])
  @@index([campaignId, status])
}

model EmailTemplate {
  id        String         @id @default(cuid())
  companyId String
  company   Company        @relation(fields: [companyId], references: [id])
  name      String
  subject   String
  body      String         @db.Text
  variables String[]       @default([])
  steps     CampaignStep[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([companyId])
}

model ContentCalendar {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  title         String
  channel       String
  scheduledAt   DateTime
  status        String   @default("Draft")
  content       String   @db.Text
  subject       String?
  reason        String?  @db.Text
  outline       String?
  isAiSuggested Boolean  @default(false)
  ownerId       String?
  owner         User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId, scheduledAt])
  @@index([status, scheduledAt])
}

model SalesKB {
  id         String    @id @default(cuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id])
  name       String
  size       String
  url        String
  category   String    @default("General")
  status     String    @default("PENDING")
  chunkCount Int       @default(0)
  error      String?   @db.Text
  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  chunks     SalesKBChunk[]

  @@index([companyId, isDeleted])
}

model SalesKBChunk {
  id         String   @id @default(cuid())
  companyId  String
  documentId String
  document   SalesKB  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex Int
  name       String
  category   String   @default("General")
  content    String   @db.Text
  embedding  Unsupported("vector(384)")?
  createdAt  DateTime @default(now())

  @@index([companyId])
  @@index([documentId])
}

model MarketingRule {
  id              String             @id @default(cuid())
  companyId       String
  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name            String
  description     String?            @db.Text
  triggerEvent    String
  conditions      Json               @default("[]") 
  actions         Json               @default("[]") 
  isActive        Boolean            @default(false)
  cooldownHours   Int                @default(24) 
  rateLimitCount  Int                @default(0)
  rateLimitWindow String             @default("DAY")
  runCount        Int                @default(0)
  lastTriggeredAt DateTime?
  createdById     String?
  runs            MarketingRuleRun[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([companyId, triggerEvent, isActive])
}

// SW-AMK-005: audit log — one row per rule evaluation.
model MarketingRuleRun {
  id           String        @id @default(cuid())
  ruleId       String
  rule         MarketingRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  companyId    String
  leadId       String?
  triggerEvent String
  matched      Boolean       @default(false)
  actionsTaken Json?
  outcome      String? 
  createdAt    DateTime      @default(now())

  @@index([ruleId, leadId, createdAt])
  @@index([companyId, createdAt])
}

model Announcement {
  id                String    @id @default(cuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title             String
  subject           String
  body              String    @db.Text
  ctaLink           String?
  channel           String    @default("EMAIL")
  audienceType      String    @default("ALL")
  segmentId         String?
  geoFilter         Json?
  status            String    @default("Draft")
  scheduledAt       DateTime?
  sentAt            DateTime?
  audienceCount     Int       @default(0)
  sentCount         Int       @default(0)
  deliveredCount    Int       @default(0)
  failedCount       Int       @default(0)
  openedCount       Int       @default(0)
  clickedCount      Int       @default(0)
  unsubscribedCount Int       @default(0)
  createdById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([companyId])
}

enum CalendarProvider {
  GOOGLE
  MICROSOFT
}

model AvailabilitySetting {
  id               String   @id @default(cuid())
  companyId        String   @unique
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  dayStart         String   @default("09:00")
  dayEnd           String   @default("17:00")
  bufferMinutes    Int      @default(15)
  slotDuration     Int      @default(30)
  workingDays      String   @default("Mon,Tue,Wed,Thu,Fri")
  timezone         String   @default("America/New_York")
  appointmentTypes Json?
  reminderHours    Int[]    @default([24, 1])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CalendarConnection {
  id             String           @id @default(cuid())
  companyId      String
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider       CalendarProvider
  accessToken    String           @db.Text
  refreshToken   String?          @db.Text
  tokenExpiresAt DateTime?
  scope          String?          @db.Text
  accountEmail   String?
  calendarId     String           @default("primary")
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([companyId, provider])
}

model SchedulingConversation {
  id           String   @id @default(cuid())
  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channel      String
  mode         String   @default("AI")
  status       String   @default("ACTIVE")
  turnCount    Int      @default(0)
  transcript   Json     @default("[]")
  offeredSlots Json?
  campaignId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([leadId])
}


model AuditLog {
  id         String   @id @default(cuid())
  companyId  String?
  actorId    String?
  actorEmail String?
  action     String
  targetType String? 
  targetId   String?
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([action, createdAt])
}

enum BlogStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
}

model BlogPost {
  id              String     @id @default(cuid())
  companyId       String
  company         Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title           String
  slug            String?
  excerpt         String?    @db.Text
  content         String     @db.Text
  category        String     @default("Market Trends")
  tags            String[]   @default([])
  status          BlogStatus @default(DRAFT)
  aiAssisted      Boolean    @default(false)
  metaTitle       String?
  metaDescription String?    @db.Text
  headings        String[]   @default([])
  tone            String?
  targetAudience  String?
  citations       Json?
  sourceNewsIds   String[]   @default([])
  approvedAt      DateTime?
  approvedById    String?
  scheduledAt     DateTime?
  publishedAt     DateTime?
  calendarEventId String?
  authorId        String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([companyId, slug])
  @@index([companyId, status])
  @@index([companyId, publishedAt])
}

model ScrapedNews {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title          String
  originalUrl    String
  summary        String   @db.Text
  source         String   @default("Google News RSS")
  imageUrl       String?
  publishedAt    DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyId, publishedAt])
}
